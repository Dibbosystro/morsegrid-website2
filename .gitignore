# ============================================
# MorseGrid Website — Whitelist .gitignore
# Only website deployment files are tracked.
# Internal docs, brand guides, agent directives,
# and prototypes stay local.
# ============================================

# Ignore everything by default
*

# ── Website files (tracked) ──────────────────
!.gitignore
!index.html
!blog.html
!blog-post.html
!style.css
!site.css
!script.js
!retell-voice.js
!vercel.json
!privacy-policy.html
!terms-of-service.html
!team.html
!favicon.png
!Morsegrid logo(color).png
!Morsegrid logo(white).png
!Morsegrid logo(black).png

# ── Team & other images (tracked) ────────────
!Team pictures/
!Team pictures/**
!Other images/
!Other images/**

# ── API routes (tracked) ─────────────────────
!api/
!api/**

# ── Blog posts (tracked) ─────────────────────
!blog/
!blog/**

# ── Always ignore these ──────────────────────
.DS_Store
.env
.env.*
node_modules/
venv/
__pycache__/
*.pyc

# ── Internal & directives (never tracked) ────
internal/
directives/
